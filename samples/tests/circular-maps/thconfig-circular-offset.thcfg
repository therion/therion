# Two maps which reference each other (circular reference) with offsets.
#
# Expected result: Therion detects and breaks the cycle. Either rejecting
# further processing, or gracefully rendering up to the broken cycle.

source
  input scraps.th2

  map map1
    scrap1
    map2 [0 4 m] none
  endmap

  map map2
    scrap2
    map1 [9 0 m] none
  endmap

  map map3
    map1
    break
    map2
  endmap

endsource

select map3

layout L
  map-header 0 0 off
endlayout

export map -layout L -o out-circular-offset.svg
