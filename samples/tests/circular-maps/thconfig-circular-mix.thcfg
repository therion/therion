# Two maps (with mixed scraps + maps) which reference each other (circular reference).
#
# Expected result: Therion detects and breaks the cycle. Either rejecting
# further processing, or gracefully rendering up to the broken cycle.

source
  input scraps.th2

  map map1
    scrap1
    map2
  endmap

  map map2
    scrap2
    map1
  endmap

  map map3
    map1
    break
    map2
  endmap

endsource

select map3

layout L
  map-header 0 0 off
endlayout

export map -layout L -o out-circular-mix.svg
