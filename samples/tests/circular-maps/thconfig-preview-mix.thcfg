# Two maps which reference each other as previews.
# Using mix of scraps and maps.
#
# Expected result: Normal map items overwrite preview items
#
# scrap1: normal
# scrap2: preview above
# scrap3: normal
# scrap4: normal

source
  input scraps.th2

  map map1
    scrap1
    scrap3
    preview above map2
  endmap

  map map2
    preview above scrap2
    scrap4
    preview below map1
  endmap

  map map3
    map1
    break
    map2
  endmap

endsource

select map3

layout L
  map-header 0 0 off
endlayout

export map -layout L -o out-preview-mix.svg
